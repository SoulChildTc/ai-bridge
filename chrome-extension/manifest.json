{
  "manifest_version": 3,
  "name": "AI Bridge",
  "version": "1.0.0",
  "description": "让终端 AI 编程助手通过浏览器与强模型对话",
  "permissions": [
    "storage",
    "activeTab",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://www.doubao.com/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.doubao.com/*",
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": ["default-configs.js", "content.js", "debug-panel.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Bridge 设置"
  }
}
